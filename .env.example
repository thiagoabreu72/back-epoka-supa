# ============================================================
# TMS Backend - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Servidor
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Supabase
# Encontre em: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # service_role (secret!)

# JWT (seus próprios tokens, independentes do Supabase Auth)
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=troque-por-outra-string-longa-e-aleatoria
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=10

# CORS
CORS_ORIGIN=http://localhost:3001

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
